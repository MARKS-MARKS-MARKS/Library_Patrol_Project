{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ROS2: check Humble environment",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source /opt/ros/humble/setup.bash && echo ROS_DISTRO=$ROS_DISTRO && which ros2 && which colcon && ros2 pkg prefix rclcpp"
      ],
      "problemMatcher": []
    },
    {
      "label": "CMake: configure project",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source /opt/ros/humble/setup.bash && cd project/out && cmake ../user -DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: build project",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source /opt/ros/humble/setup.bash && cmake --build project/out"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Project: build and deploy",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source /opt/ros/humble/setup.bash && cd project/user && ./build.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "ROS2: colcon build current workspace",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source /opt/ros/humble/setup.bash && colcon build --symlink-install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
