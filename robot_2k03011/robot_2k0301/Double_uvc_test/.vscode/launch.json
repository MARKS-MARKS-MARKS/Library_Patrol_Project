{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug project/out/double_uvc_4",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/project/out/double_uvc_4",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "ROS_DISTRO",
          "value": "humble"
        },
        {
          "name": "AMENT_PREFIX_PATH",
